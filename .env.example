# Copy this file to `.env` and fill in your real Shopify credentials.
# NEVER commit `.env` to git — it's in .gitignore for that reason.
#
# How to get these:
# 1. In Shopify admin: Settings → Apps and sales channels → Develop apps → Create app
# 2. Configure Storefront API access → enable scopes:
#    - unauthenticated_read_product_listings
#    - unauthenticated_read_product_inventory
#    - unauthenticated_write_checkouts
#    - unauthenticated_read_checkouts
# 3. Install app → copy the "Storefront API access token"
# 4. Your domain is your `*.myshopify.com` URL (NOT your custom domain)

VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here

# Optional: Klaviyo list ID for VIP signups (leave blank to skip)
VITE_KLAVIYO_LIST_ID=
VITE_KLAVIYO_PUBLIC_KEY=

# Optional: Launch date countdown target (ISO 8601). If blank, defaults to 30 days from first visit.
VITE_LAUNCH_DATE=
